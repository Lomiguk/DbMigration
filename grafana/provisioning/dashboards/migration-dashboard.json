{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "Migration Throughput (rows/sec)",
      "type": "timeseries",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(migration_rows_total[1m])",
          "legendFormat": "{{table}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rows/sec",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Batch Duration (seconds)",
      "type": "timeseries",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(migration_batch_duration_seconds_sum[1m]) / rate(migration_batch_duration_seconds_count[1m])",
          "legendFormat": "{{table}} - {{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "HikariCP Connections",
      "type": "timeseries",
      "id": 3,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "{{pool}} - active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle",
          "legendFormat": "{{pool}} - idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending",
          "legendFormat": "{{pool}} - pending",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Mapping Cache Size",
      "type": "stat",
      "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "mapping_cache_size",
          "legendFormat": "Cache entries",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 250000 },
              { "color": "red", "value": 450000 }
            ]
          }
        }
      }
    },
    {
      "title": "Replication Lag (bytes)",
      "type": "timeseries",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "replication_lag_bytes",
          "legendFormat": "Lag",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Replication Events Applied",
      "type": "stat",
      "id": 6,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "replication_events_applied_total",
          "legendFormat": "Events",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "Total Migrated Rows",
      "type": "stat",
      "id": 7,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "migration_rows_total",
          "legendFormat": "{{table}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    }
  ],
