{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Total Migrated Rows",
      "type": "stat",
      "id": 7,
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(migration_rows_total)", "legendFormat": "Total Rows" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "axisPlacement": "auto", "axisLabel": "", "drawStyle": "line", "lineInterpolation": "linear", "showPoints": "auto", "barAlignment": 0, "lineWidth": 1, "fillOpacity": 10, "gradientMode": "none", "spanNulls": false, "insertNulls": false, "hideFrom": { "tooltip": false, "viz": false, "legend": false } }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": [ "lastNotNull" ], "fields": "" },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "title": "System Resource Load (CPU & RAM)",
      "type": "timeseries",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "process_cpu_usage", "legendFormat": "CPU Usage" },
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "Heap RAM Used" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisPlacement": "auto", "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Heap RAM Used" }, "properties": [ { "id": "unit", "value": "bytes" } ] },
          { "matcher": { "id": "byName", "options": "CPU Usage" }, "properties": [ { "id": "unit", "value": "percentunit" } ] }
        ]
      }
    },
    {
      "title": "Migration Throughput (rows/sec)",
      "type": "timeseries",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [ { "expr": "rate(migration_rows_total[1m])", "legendFormat": "{{table}}" } ],
      "fieldConfig": { "defaults": { "unit": "rows/sec" } }
    },
    {
      "title": "Replication Lag (bytes)",
      "type": "timeseries",
      "id": 5,
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "targets": [ { "expr": "replication_lag_bytes", "legendFormat": "Lag" } ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Replication Events Applied",
      "type": "stat",
      "id": 6,
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
      "targets": [ { "expr": "replication_events_applied_total", "legendFormat": "Events" } ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" } } }
    }
  ],
  "schemaVersion": 39,
  "time": { "from": "now-15m", "to": "now" },
  "title": "DB Migration Observatory",
  "uid": "db-migration-001"
}